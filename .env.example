# Server
SERVER_PORT=8585
LOG_LEVEL=info

# Database
# For local development: DB_HOST=localhost
# For Docker: DB_HOST=host.docker.internal or your DB server IP (e.g. 192.168.1.101)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=topicvoting
DB_SSLMODE=disable

# Classifier
CLASSIFIER_URL=http://localhost:4747
CLASSIFIER_THRESHOLD=0.5
CLASSIFIER_TIMEOUT_S=2

# Vote Processing
VOTE_QUEUE_CAPACITY=1000
CLASSIFIER_WORKERS=4

# Database Flush
DB_FLUSH_INTERVAL_MS=500

# WebSocket
WS_PING_INTERVAL_S=30
WS_PONG_TIMEOUT_S=10

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5442

# Frontend (for Docker)
VITE_API_URL=http://localhost:8585
